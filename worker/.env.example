# Worker env — copy to worker/.env and fill in values

# Native Redis TCP connection (NOT the REST API)
# Get from: Upstash Dashboard → your database → Connect → ioredis
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379

# Supabase (same as main app)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: VPS proxy for geo-blocked APIs
# VPS_PROXY_URL=
# VPS_PROXY_KEY=
