{
  "name": "arena-worker",
  "version": "1.0.0",
  "description": "Arena data scraping worker service",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "scrape:all": "tsx src/cli.ts scrape --all",
    "scrape:binance": "tsx src/cli.ts scrape --source binance",
    "scrape:bybit": "tsx src/cli.ts scrape --source bybit",
    "scrape:bitget": "tsx src/cli.ts scrape --source bitget"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "dotenv": "^17.2.3",
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
