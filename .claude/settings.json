{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": {
        "tool_name": "Write|Edit"
      },
      "hooks": [
        {
          "type": "command",
          "command": "npx tsc --noEmit $CLAUDE_FILE_PATH 2>&1 | head -5 || true"
        }
      ]
    },
    {
      "event": "Stop",
      "hooks": [
        {
          "type": "command",
          "command": "npm run type-check 2>&1 | tail -10"
        }
      ]
    }
  ]
}
