{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Write", "Edit", "Read",
      "WebFetch", "WebSearch",
      "Agent", "Glob", "Grep",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(rm -rf *)", "Bash(sudo *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/auto-commit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run build 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
