{
  "permissions": {
    "allow": [
      "Bash(npm *)", "Bash(npx *)", "Bash(node *)",
      "Bash(git add *)", "Bash(git commit *)", "Bash(git tag *)",
      "Bash(git diff *)", "Bash(git log *)", "Bash(git status*)",
      "Bash(git checkout -- *)", "Bash(git clean *)",
      "Bash(cat *)", "Bash(ls *)", "Bash(find *)", "Bash(grep *)",
      "Bash(mkdir *)", "Bash(cp *)", "Bash(mv *)",
      "Bash(curl *)", "Bash(echo *)", "Bash(head *)", "Bash(tail *)",
      "Write", "Edit", "Read"
    ],
    "deny": [
      "Bash(rm -rf *)", "Bash(sudo *)", "Bash(git push * --force*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/auto-commit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run build 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
