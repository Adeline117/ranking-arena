{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Write", "Edit", "Read",
      "WebFetch", "WebSearch",
      "Agent", "Glob", "Grep",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(rm -rf *)", "Bash(sudo *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-migration-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -20"
          }
        ]
      }
    ]
  }
}
