# Vercel 忽略文件
# 这些文件不会上传到 Vercel

# 开发文件
.env
.env.*
.env.local
.env.development
.env.test

# 测试文件
**/__tests__/**
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
coverage/
.nyc_output/

# 文档
docs/
*.md
!README.md

# 脚本（只上传 build lifecycle 直接依赖的文件）
# ⚠️ 目录级排除无法被子文件 ! 负向穿透（gitignore 语义，2026-07-02 实测：
# !scripts/xxx.sh 无效仍 ENOENT）——ignoreCommand 因此内联在 vercel.json，
# 不要再让它依赖 scripts/ 下的文件
scripts/*
!scripts/qa/
scripts/qa/*
!scripts/qa/check-bigint-build-output.mjs

# 构建工具
.storybook/
storybook-static/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# 备份 (SQL dumps, 数GB)
backups/

# 大型报告
BITGET_REGRESSION_REPORT.md

# Cloudflare Worker (独立部署)
cloudflare-worker/

# 其他
.DS_Store
*.log
node_modules/
.next/
out/
dist/
build/

# Worker 目录（独立部署）
worker/

# Android/iOS
android/
ios/

# E2E 测试
e2e/
playwright-report/
test-results/

# Ingest worker 浏览器 profiles（7.7GB 本地卷,gitignored;易变 cache 会在上传中消失
# → `vercel deploy` ENOENT。git-gate 路径从仓库构建不受影响,此项专防本地 CLI 部署）
.arena-ingest/

# Claude Code 会话/worktree（本地卷,构建无关）
.claude/
