# Vercel 忽略文件
# 这些文件不会上传到 Vercel

# 开发文件
.env
.env.*
.env.local
.env.development
.env.test

# 测试文件
**/__tests__/**
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
coverage/
.nyc_output/

# 文档
docs/
*.md
!README.md

# 脚本（独立运维工具不上传；build lifecycle checker 必须留在仓库根）
# Vercel CLI 56.2.1 的实际 `deploy --dry` 清单不遵循嵌套负向规则，
# 因此禁止再从这个被排除目录引用 package lifecycle 文件。
scripts/

# 构建工具
.storybook/
storybook-static/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# 备份 (SQL dumps, 数GB)
backups/

# 大型报告
BITGET_REGRESSION_REPORT.md

# Cloudflare Worker (独立部署)
cloudflare-worker/

# 其他
.DS_Store
*.log
node_modules/
.next/
out/
dist/
build/

# Worker 目录（独立部署）
worker/

# Android/iOS
android/
ios/

# E2E 测试
e2e/
playwright-report/
test-results/

# Ingest worker 浏览器 profiles（7.7GB 本地卷,gitignored;易变 cache 会在上传中消失
# → `vercel deploy` ENOENT。git-gate 路径从仓库构建不受影响,此项专防本地 CLI 部署）
.arena-ingest/

# Claude Code 会话/worktree（本地卷,构建无关）
.claude/
