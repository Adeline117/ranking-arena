{
  "crons": [
    {
      "path": "/api/cron/fetch-followed-traders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/check-data-freshness",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/fetch-details?concurrency=50&limit=300",
      "schedule": "30 */2 * * *"
    },
    {
      "path": "/api/cron/run-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/run-jobs?max=20",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/run-jobs?max=10&prewarm=true",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cleanup-deleted-accounts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refresh-hot-scores",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/calculate-tiers",
      "schedule": "*/15 * * * *"
    },
    { "path": "/api/cron/fetch-traders/bybit_spot",     "schedule": "57 */4 * * *" },
    { "path": "/api/cron/fetch-traders/bitget_spot",   "schedule": "0 */4 * * *" },
    { "path": "/api/cron/fetch-traders/okx_futures",    "schedule": "3 */4 * * *" },
    { "path": "/api/cron/fetch-traders/okx_web3",       "schedule": "6 */4 * * *" },
    { "path": "/api/cron/fetch-traders/bingx",          "schedule": "9 */4 * * *" },
    { "path": "/api/cron/fetch-traders/gateio",         "schedule": "12 */4 * * *" },
    { "path": "/api/cron/fetch-traders/mexc",           "schedule": "15 */4 * * *" },
    { "path": "/api/cron/fetch-traders/coinex",         "schedule": "18 */4 * * *" },
    { "path": "/api/cron/fetch-traders/kucoin",         "schedule": "21 */4 * * *" },
    { "path": "/api/cron/fetch-traders/htx",            "schedule": "24 */4 * * *" },
    { "path": "/api/cron/fetch-traders/weex",           "schedule": "27 */4 * * *" },
    { "path": "/api/cron/fetch-traders/phemex",         "schedule": "30 */4 * * *" },
    { "path": "/api/cron/fetch-traders/xt",             "schedule": "33 */4 * * *" },
    { "path": "/api/cron/fetch-traders/pionex",         "schedule": "36 */4 * * *" },
    { "path": "/api/cron/fetch-traders/gmx",            "schedule": "39 */4 * * *" },
    { "path": "/api/cron/fetch-traders/kwenta",         "schedule": "42 */4 * * *" },
    { "path": "/api/cron/fetch-traders/gains",          "schedule": "45 */4 * * *" },
    { "path": "/api/cron/fetch-traders/mux",            "schedule": "48 */4 * * *" },
    { "path": "/api/cron/fetch-traders/lbank",          "schedule": "51 */4 * * *" },
    { "path": "/api/cron/fetch-traders/blofin",         "schedule": "54 */4 * * *" },
    { "path": "/api/cron/discover-traders",    "schedule": "56 */4 * * *" },
    { "path": "/api/cron/discover-rankings",   "schedule": "58 */4 * * *" },
    { "path": "/api/scrape/proxy?period=all",  "schedule": "0 2,6,10,14,18,22 * * *" }
  ],
  "headers": [
    {
      "source": "/api/traders",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/posts",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/api/market/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/api/traders/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/rankings",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/trader/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/reviews",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/avoid-list",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=120, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/portfolio/suggestions",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=900"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
