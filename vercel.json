    {
      "path": "/api/cron/compute-derived-metrics",
      "schedule": "20 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-data",
      "schedule": "6 1 * * *"
    },
    {
      "path": "/api/cron/snapshot-ranks",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/fetch-funding-rates",
      "schedule": "56 */8 * * *"
    },
    {
      "path": "/api/cron/fetch-open-interest",
      "schedule": "16 */6 * * *"
    },
    {
      "path": "/api/cron/check-trader-alerts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/data-reconciliation",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/retry-dead-letters",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/precompute-composite",
      "schedule": "27 */2 * * *"
    },
    {
      "path": "/api/cron/backfill-avatars?platform=drift,toobit,bitfinex,etoro,gains&limit=400",
      "schedule": "35 2 * * *"
    },
    {
      "path": "/api/cron/detect-contracts?limit=500",
      "schedule": "10 */6 * * *"
    },
    {
      "path": "/api/cron/health-check-all",
      "schedule": "25 */6 * * *"
    },
    {
      "path": "/api/cron/cleanup-violations",
      "schedule": "57 */6 * * *"
    },
    {
      "path": "/api/cron/scan-data-quality",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/expire-mutes",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/sync-ranking-store",
      "schedule": "12,27,42,57 * * * *"
    },
    {
      "path": "/api/cron/score-backtest",
      "schedule": "37 3 * * 1"
    },
    {
      "path": "/api/cron/compute-leaderboard-watchdog",
      "schedule": "21,51 * * * *"
    }
