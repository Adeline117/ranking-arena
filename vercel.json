{
  "buildCommand": "npm run build",
  "ignoreCommand": "[ \"$VERCEL_ENV\" = production ] || exit 1; case \"$VERCEL_GIT_COMMIT_MESSAGE\" in *\"[deploy-force]\"*) exit 1;; esac; [ \"$VERCEL_GIT_COMMIT_REF\" = main ] && exit 0 || exit 1",
  "regions": ["hnd1"],
  "crons": [
    {
      "path": "/api/cron/flash-news-fetch",
