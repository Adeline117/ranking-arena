    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "2 0 * * *"
    },
    {
      "path": "/api/cron/meta-monitor",
      "schedule": "23 */6 * * *"
    },
    {
      "path": "/api/cron/batch-5min",
      "schedule": "3,18,33,48 * * * *"
    },
    {
      "path": "/api/cron/warm-cache",
      "schedule": "4,34 * * * *"
    },
    {
