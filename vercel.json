{
  "crons": [
    {
      "path": "/api/scrape/proxy?period=all",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-followed-traders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/check-data-freshness",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/discover-rankings",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-traders/bitget_spot",
      "schedule": "25 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-traders/mexc",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-traders/coinex",
      "schedule": "35 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-traders/okx_web3",
      "schedule": "40 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-traders/kucoin",
      "schedule": "45 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-traders/gmx",
      "schedule": "50 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-details?concurrency=50&limit=300",
      "schedule": "30 */2 * * *"
    },
    {
      "path": "/api/cron/discover-rankings",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/run-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/run-jobs?max=20",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/run-jobs?max=10&prewarm=true",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/discover-traders",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/cleanup-deleted-accounts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refresh-hot-scores",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/traders",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/posts",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/api/market/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/api/traders/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/rankings",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/trader/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/reviews",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/rankings",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/trader/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/avoid-list",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=120, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/portfolio/suggestions",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=900"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
