      "schedule": "47 6 * * *"
    },
    {
      "path": "/api/cron/cleanup-deleted-accounts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/recount-follow-counts",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/cleanup-stuck-logs",
      "schedule": "27 */6 * * *"
    },
    {
