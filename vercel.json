{
  "regions": [
    "hnd1",
    "sin1",
    "hkg1"
  ],
  "crons": [
    {
      "path": "/api/cron/auto-news-post",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/flash-news-fetch",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/compute-leaderboard",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/fetch-followed-traders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/check-data-freshness",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/fetch-details?tier=hot&concurrency=50&limit=100",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/fetch-details?tier=active&concurrency=40&limit=200",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/fetch-details?tier=normal&concurrency=30&limit=300",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-details?tier=dormant&concurrency=20&limit=500",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/batch-5min",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/run-jobs?max=20",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/cleanup-deleted-accounts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/calculate-tiers",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/batch-discover",
      "schedule": "56 */4 * * *"
    },
    {
      "path": "/api/scrape/proxy?period=all",
      "schedule": "0 2,6,10,14,18,22 * * *"
    },
    {
      "path": "/api/cron/subscription-expiry",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/fetch-market-data?type=prices",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/cron/calculate-advanced-metrics",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/aggregate-daily-snapshots",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/fetch-funding-rates",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/fetch-open-interest",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/batch-fetch-traders?group=a",
      "schedule": "55 */3 * * *"
    },
    {
      "path": "/api/cron/batch-fetch-traders?group=b",
      "schedule": "2 */4 * * *"
    },
    {
      "path": "/api/cron/batch-fetch-traders?group=c",
      "schedule": "22 */6 * * *"
    },
    {
      "path": "/api/cron/batch-fetch-traders?group=d",
      "schedule": "40 */6 * * *"
    },
    {
      "path": "/api/cron/batch-fetch-traders?group=e",
      "schedule": "57 */8 * * *"
    },
    {
      "path": "/api/cron/batch-enrich",
      "schedule": "10 */4 * * *"
    },
    {
      "path": "/api/cron/check-trader-alerts",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/traders",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/posts",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/api/market/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/api/traders/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/rankings",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/trader/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/reviews",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/avoid-list",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=120, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/portfolio/suggestions",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=900"
        }
      ]
    },
    {
      "source": "/api/library",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=600, stale-while-revalidate=1800"
        }
      ]
    },
    {
      "source": "/api/library/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=600, stale-while-revalidate=1800"
        }
      ]
    },
    {
      "source": "/api/search",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/api/search/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=30, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/api/stats",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/v2/rankings",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/flash-news",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}