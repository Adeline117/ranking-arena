        "绷",
        "服了",
        "离谱",
        "啊这",
        "笑死",
        "不是吧",
        "太猛了",
        "哈哈哈",
        "确实",
        "来了",
        "真的假的"
      ],
      "context_aware": {
        "price_up": [
          "来了",
          "hodl",
          "told you",
          "weekly close关键",
          "不敢空了"
        ],
        "price_down": [
          "rip",
          "F",
          "pain",
          "做空的赚了",
          "该加仓了"
        ],
        "loss_post": [
          "been there",
          "F",
          "做空就是送钱",
          "别空了兄弟",
          "rip bro"
        ],
        "gain_post": [
          "nice",
          "大佬",
          "teach me",
          "怎么做到的"
        ],
        "question": [
          "i think so",
          "not sure",
          "同问",
          "试了 挺快的",
          "我也想知道"
        ],
        "analysis": [
          "有道理",
          "disagree but ok",
          "interesting take",
          "不一定"
        ]
      }
    }
