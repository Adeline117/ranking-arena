# ============================================
# Staging Environment Configuration Template
# ============================================
# Copy this file to .env.staging and fill in your values
#
# Usage:
#   cp scripts/staging/.env.template scripts/staging/.env.staging
#   # Edit .env.staging with your values
#   source scripts/staging/.env.staging
#   ./scripts/staging/test-runner.sh

# ============================================
# Required Variables
# ============================================

# Your staging deployment URL
# Example: https://ranking-arena-staging.vercel.app
STAGING_URL="https://your-staging-url.vercel.app"

# CRON secret for authenticating cron endpoints
# Find this in: Vercel Dashboard → Project → Settings → Environment Variables
# IMPORTANT: Must be 32+ characters
CRON_SECRET="your-cron-secret-here"

# Admin access token for protected endpoints
# How to get:
#   1. Open staging site in browser
#   2. Login as admin
#   3. Open DevTools (F12)
#   4. Go to: Application → Local Storage → supabase.auth.token
#   5. Copy the access_token value
ACCESS_TOKEN="your-access-token-here"

# ============================================
# Optional Variables (for manual testing)
# ============================================

# Admin email (for login)
ADMIN_EMAIL="your-admin@example.com"

# Specific trader ID for testing
TEST_TRADER_ID="example_trader_123"

# Specific platform for testing
TEST_PLATFORM="binance"

# ============================================
# Feature Flags (current state in staging)
# ============================================

# Smart Scheduler enabled state (check Vercel env vars)
# ENABLE_SMART_SCHEDULER=false

# Anomaly Detection enabled state (check Vercel env vars)
# ENABLE_ANOMALY_DETECTION=false

# ============================================
# Notes
# ============================================

# 1. DO NOT commit .env.staging to git (already in .gitignore)
# 2. Update values after each staging deployment
# 3. ACCESS_TOKEN expires, refresh periodically
# 4. Keep CRON_SECRET secure and private
