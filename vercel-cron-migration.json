{
  "migration": "batch-fetch-traders → unified-connector",
  "date": "2026-03-11",
  "strategy": "Replace batch-fetch-traders + batch-enrich with unified-connector per platform",
  
  "old_system": {
    "description": "Separate fetch + enrich cron jobs",
    "jobs": 16,
    "notes": [
      "12× batch-fetch-traders (grouped by frequency)",
      "4× batch-enrich (periods: 7D, 30D, 90D, all)"
    ]
  },
  
  "new_system": {
    "description": "Unified connector per platform (fetch + enrich in one job)",
    "platforms": 29,
    "notes": [
      "Each platform has dedicated cron job with appropriate frequency",
      "Enrichment runs inline after fetch",
      "Better monitoring, alerting, and error handling via ConnectorRunner"
    ]
  },
  
  "frequency_groups": {
    "3h": {
      "schedule": "0,20,40 */3 * * *",
      "platforms": ["binance_futures", "binance_spot", "bybit", "bitget_futures", "okx_futures"],
      "notes": "High-priority CEX, stagger by 20min to avoid spikes"
    },
    "4h": {
      "schedule": "5,25,45 */4 * * *",
      "platforms": ["hyperliquid", "gmx", "jupiter_perps", "okx_web3", "aevo", "xt"],
      "notes": "Top DEX + mid-priority, stagger by 20min"
    },
    "6h": {
      "schedule": "10,30,50 */6 * * *",
      "platforms": [
        "gains", "htx_futures", "dydx", "bybit_spot", "coinex", "binance_web3", 
