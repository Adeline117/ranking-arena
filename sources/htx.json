{
  "platform": "htx",
  "market_types": ["futures"],
  "futures": {
    "leaderboard_endpoints": [
      {
        "method": "POST",
        "url": "https://www.htx.com/bapi/copy-trade/v1/public/trader/list",
        "type": "api",
        "body": {
          "page": 1,
          "pageSize": 20,
          "sortBy": "roi",
          "period": "30d"
        },
        "notes": "period: 7d, 30d, 90d. sortBy: roi, pnl, followers"
      },
      {
        "url": "https://www.htx.com/v1/copy-trading/public/trader/list",
        "method": "GET",
        "type": "api",
        "headers": {
          "Origin": "https://www.htx.com",
          "Referer": "https://www.htx.com/copy-trading"
        },
        "query_params": {
          "page": "1",
          "pageSize": "50",
          "sortField": "yield_rate",
          "sortOrder": "desc",
          "periodDays": "7"
        },
        "pagination": {
          "type": "page",
          "page_size": 50,
          "max_pages": 1,
          "param_name": "page"
        },
        "response_path": "data.list",
        "window_param": "periodDays",
        "sort_param": "sortField",
        "notes": "Alternative endpoint with GET method"
      }
    ],
    "profile_endpoints": [
      {
        "method": "GET",
        "url": "https://www.htx.com/bapi/copy-trade/v1/public/trader/detail?uid={trader_key}",
        "type": "api"
      }
    ],
    "trader_key_field": "uid",
    "roi_sort_supported": true,
    "roi_sort_mechanism": "platform_native",
    "roi_sort_param": "sortBy=roi (DESC default)",
    "window_support": {
      "7d": { "supported": true, "param": "period=7d" },
      "30d": { "supported": true, "param": "period=30d" },
      "90d": { "supported": true, "param": "period=90d" }
    },
    "field_map": {
      "uid": "trader_key",
      "trader_id": "trader_key (alt)",
      "nickName": "display_name",
      "nick_name": "display_name (alt)",
      "avatar": "avatar_url",
      "roi": "roi (percentage)",
      "yield_rate": "roi (alt)",
      "pnl": "pnl (USD)",
      "winRate": "win_rate",
      "win_rate": "win_rate (alt)",
      "maxDrawdown": "max_drawdown",
      "max_drawdown": "max_drawdown (alt)",
      "followerCount": "followers",
      "follower_count": "followers (alt)",
      "copyCount": "copiers",
      "copier_count": "copiers (alt)",
      "trade_count": "trades_count"
    },
    "rate_limits": {
      "estimated_rpm": 10,
      "cloudflare_protected": true,
      "notes": "HTX has frequent DOM/API changes. CF protected."
    },
    "anti_scraping": {
      "cloudflare": true,
      "fingerprinting": true,
      "mitigation": "API interception preferred. DOM frequently changes structure."
    },
    "proof": [
