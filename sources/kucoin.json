{
  "platform": "kucoin",
  "market_types": ["futures"],
  "futures": {
    "leaderboard_endpoints": [
      {
        "method": "GET",
        "url": "https://www.kucoin.com/_api/copy-trade/leader/public/list",
        "type": "api",
        "params": {
          "pageNo": 1,
          "pageSize": 20,
          "orderBy": "ROI",
          "period": "THIRTY_DAY"
        },
        "notes": "period: SEVEN_DAY, THIRTY_DAY, NINETY_DAY. orderBy: ROI, PNL, FOLLOWERS"
      },
      {
        "url": "https://www.kucoin.com/_api/copy-trade/leader/ranking",
        "method": "GET",
        "type": "api",
        "headers": {
          "Referer": "https://www.kucoin.com/copy-trading",
          "Origin": "https://www.kucoin.com"
        },
        "query_params": {
          "page": "1",
          "pageSize": "20",
          "sortBy": "ROI",
          "sortOrder": "DESC",
          "period": "WEEK"
        },
        "pagination": {
          "type": "page",
          "page_size": 20,
          "max_pages": 5,
          "param_name": "page"
        },
        "response_path": "data.items",
        "window_param": "period",
        "sort_param": "sortBy",
        "notes": "Alternative endpoint"
      }
    ],
    "profile_endpoints": [
      {
        "method": "GET",
        "url": "https://www.kucoin.com/_api/copy-trade/leader/public/detail?uid={trader_key}",
        "type": "api"
      },
      {
        "url": "https://www.kucoin.com/_api/copy-trade/leader/detail",
        "method": "GET",
        "type": "api",
        "headers": {
          "Origin": "https://www.kucoin.com"
        },
        "query_params": {
          "leaderId": ""
        },
        "response_path": "data"
      },
      {
        "url": "https://www.kucoin.com/_api/copy-trade/leader/performance",
        "method": "GET",
        "type": "api",
        "headers": {
          "Origin": "https://www.kucoin.com"
        },
        "query_params": {
          "leaderId": "",
          "period": "WEEK"
        },
        "response_path": "data"
      }
    ],
    "trader_key_field": "uid",
    "roi_sort_supported": true,
    "roi_sort_mechanism": "platform_native",
    "roi_sort_param": "orderBy=ROI (returns DESC)",
    "window_support": {
      "7d": { "supported": true, "param": "period=SEVEN_DAY" },
      "30d": { "supported": true, "param": "period=THIRTY_DAY" },
      "90d": { "supported": true, "param": "period=NINETY_DAY" }
    },
    "field_map": {
      "uid": "trader_key",
      "leaderId": "trader_key (alt)",
      "nickName": "display_name",
      "avatar": "avatar_url",
      "roi": "roi (percentage)",
      "totalPnl": "pnl",
      "pnl": "pnl (alt)",
      "winRate": "win_rate",
      "maxDrawdown": "max_drawdown",
      "followerCount": "followers",
      "currentCopyCount": "copiers",
      "copierCount": "copiers (alt)",
      "totalOrders": "trades_count",
      "aum": "aum"
    },
    "rate_limits": {
      "estimated_rpm": 15,
      "cloudflare_protected": true,
      "notes": "CF protected, moderate limits"
    },
    "proof": [
      {
        "url": "https://www.kucoin.com/_api/copy-trade/leader/ranking?page=1&pageSize=20&sortBy=ROI&sortOrder=DESC&period=WEEK",
