{
  "platform": "coinex",
  "market_types": ["futures"],
  "futures": {
    "leaderboard_endpoints": [
      {
        "method": "GET",
        "url": "https://www.coinex.com/res/copy-trading/traders",
        "type": "api",
        "params": {
          "page": 1,
          "limit": 20,
          "sort_by": "roi",
          "period": "30d"
        },
        "notes": "period: 7d, 30d. No 90d support."
      },
      {
        "url": "https://www.coinex.com/res/copy-trading/traders",
        "method": "GET",
        "type": "api",
        "headers": {
          "Referer": "https://www.coinex.com/copy-trading",
          "Origin": "https://www.coinex.com"
        },
        "query_params": {
          "page": "1",
          "limit": "20",
          "order_by": "roi",
          "order_type": "desc",
          "days": "7"
        },
        "pagination": {
          "type": "page",
          "page_size": 20,
          "max_pages": 5,
          "param_name": "page"
        },
        "response_path": "data.items",
        "window_param": "days",
        "sort_param": "order_by",
        "notes": "Alternative param format using 'days' instead of 'period'"
      }
    ],
    "profile_endpoints": [
      {
        "method": "GET",
        "url": "https://www.coinex.com/res/copy-trading/trader/{trader_key}/detail",
        "type": "api"
      },
      {
        "url": "https://www.coinex.com/res/copy-trading/trader/{trader_id}",
        "method": "GET",
        "type": "api",
        "headers": {
          "Origin": "https://www.coinex.com"
        },
        "response_path": "data"
      },
      {
        "url": "https://www.coinex.com/res/copy-trading/trader/{trader_id}/performance",
        "method": "GET",
        "type": "api",
        "headers": {
          "Origin": "https://www.coinex.com"
        },
        "query_params": {
          "days": "7"
        },
        "response_path": "data"
      }
    ],
    "trader_key_field": "trader_id",
    "roi_sort_supported": true,
    "roi_sort_mechanism": "platform_native",
    "roi_sort_param": "sort_by=roi",
    "window_support": {
      "7d": { "supported": true, "param": "period=7d" },
      "30d": { "supported": true, "param": "period=30d" },
      "90d": { "supported": false, "reason": "CoinEx copy trading leaderboard only provides 7D and 30D windows. Platform confirmed via API: 90D period param returns error." }
    },
    "field_map": {
      "trader_id": "trader_key",
      "nickname": "display_name",
      "nick_name": "display_name (alt)",
      "avatar": "avatar_url",
      "roi": "roi (percentage)",
      "profit": "pnl",
      "pnl": "pnl (alt)",
      "win_rate": "win_rate",
      "max_drawdown": "max_drawdown",
      "followers": "followers",
      "follower_count": "followers (alt)",
      "copiers": "copiers",
      "copier_count": "copiers (alt)",
      "trade_count": "trades_count"
    },
    "rate_limits": {
      "estimated_rpm": 15,
      "cloudflare_protected": false,
