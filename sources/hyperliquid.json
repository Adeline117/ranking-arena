{
  "platform": "hyperliquid",
  "market_type": "perp",
  "leaderboard_endpoints": [
    {
      "url": "https://api.hyperliquid.xyz/info",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json"
      },
      "body_template": {
        "type": "leaderboard",
        "timeWindow": "week"
      },
      "pagination": {
        "type": "offset",
        "page_size": 100,
        "max_pages": 1,
        "param_name": "limit"
      },
      "response_path": "leaderboardRows",
      "window_param": "timeWindow"
    },
    {
      "url": "https://api.hyperliquid.xyz/info",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json"
      },
      "body_template": {
        "type": "frontendLeaderboard",
        "timeWindow": "week"
      },
      "pagination": {
        "type": "offset",
        "page_size": 100,
        "max_pages": 1,
        "param_name": "limit"
      },
      "response_path": "leaderboard",
      "window_param": "timeWindow"
    }
  ],
  "profile_endpoints": [
    {
      "url": "https://api.hyperliquid.xyz/info",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json"
      },
      "body_template": {
        "type": "clearinghouseState",
        "user": ""
      },
      "response_path": "marginSummary"
