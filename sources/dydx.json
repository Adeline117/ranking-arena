{
  "platform": "dydx",
  "market_types": ["perp"],
  "perp": {
    "leaderboard_endpoints": [
      {
        "method": "GET",
        "url": "https://indexer.dydx.trade/v4/leaderboard/pnl?period=PERIOD_30D&limit=100&startingBeforeOrAt={timestamp}",
        "type": "api",
        "notes": "v4 indexer API. period: PERIOD_7D, PERIOD_30D, PERIOD_90D, PERIOD_1Y. Returns pnlRanking array sorted by PnL DESC. ROI sort requires client-side computation."
      },
      {
        "url": "https://indexer.dydx.trade/v4/leaderboard",
        "method": "GET",
        "type": "api",
        "query_params": {
          "period": "WEEKLY",
          "limit": "200"
        },
        "pagination": {
          "type": "offset",
          "page_size": 200,
          "max_pages": 1,
          "param_name": "limit"
        },
        "response_path": "leaderboard",
        "window_param": "period",
        "notes": "Alternative leaderboard endpoint"
      },
      {
        "method": "GET",
        "url": "https://indexer.dydx.trade/v4/addresses/{address}/subaccounts",
        "type": "api",
        "notes": "Get subaccount details for equity/balance"
      }
    ],
    "profile_endpoints": [
      {
        "method": "GET",
        "url": "https://indexer.dydx.trade/v4/addresses/{trader_key}/subaccounts/0",
        "type": "api",
        "notes": "Subaccount 0 is primary"
      },
      {
        "method": "GET",
        "url": "https://indexer.dydx.trade/v4/fills?address={trader_key}&subaccountNumber=0&limit=100",
        "type": "api"
      },
      {
        "url": "https://indexer.dydx.trade/v4/addresses/{address}",
        "method": "GET",
        "type": "api",
        "response_path": "subaccounts"
      },
      {
        "url": "https://indexer.dydx.trade/v4/addresses/{address}/subaccountNumber/0/historicalPnl",
        "method": "GET",
        "type": "api",
        "query_params": {
          "period": "MONTHLY"
        },
        "response_path": "historicalPnl"
      }
    ],
    "trader_key_field": "dydx1... address (bech32) or 0x... (evm)",
    "roi_sort_supported": false,
    "roi_sort_mechanism": "arena_computed",
    "roi_sort_notes": "dYdX v4 leaderboard sorts by absolute PnL (not ROI). We fetch PnL-sorted data, compute ROI from equity, then re-sort by ROI.",
    "window_support": {
      "7d": { "supported": true, "param": "period=PERIOD_7D" },
      "30d": { "supported": true, "param": "period=PERIOD_30D" },
      "90d": { "supported": true, "param": "period=PERIOD_90D" }
    },
    "field_map": {
      "address": "trader_key",
      "pnl": "pnl (USD, from leaderboard endpoint)",
      "totalPnl": "pnl (alt, string)",
      "pnlPercent": "roi (alt, decimal)",
      "equity": "derived: used to compute ROI = pnl/equity_at_start",
      "currentEquity": "from subaccount endpoint",
      "username": "display_name (if available)",
      "totalTrades": "trades_count",
      "winRate": "win_rate",
      "maxDrawdown": "max_drawdown"
    },
    "missing_fields": ["win_rate", "followers", "copiers", "aum", "display_name", "avatar_url"],
    "missing_reason": "dYdX v4 is a decentralized exchange. No copy trading, no user profiles. Addresses are pseudonymous. Win rate and drawdown computed from fills/subaccount history.",
    "timeseries_endpoints": [
      {
        "method": "GET",
        "url": "https://indexer.dydx.trade/v4/historical-pnl?address={trader_key}&subaccountNumber=0&limit=90",
        "notes": "Daily PnL history for equity curve construction"
      }
    ],
    "rate_limits": {
      "estimated_rpm": 60,
      "cloudflare_protected": false,
      "notes": "Public indexer API. Rate limit: 100 req/10s documented."
    },
    "anti_scraping": {
      "cloudflare": false,
      "fingerprinting": false,
      "mitigation": "Standard REST API, well-documented"
    },
    "proof": [
      {
        "url": "https://indexer.dydx.trade/v4/leaderboard?period=WEEKLY&limit=200",
        "method": "GET",
        "response_fields_sample": {
          "leaderboard[0].address": "dydx1abc123def456ghi789jkl012mno345pqr678stu",
          "leaderboard[0].subaccountId": "0",
          "leaderboard[0].username": "dydx_trader",
          "leaderboard[0].totalPnl": "45678.90",
          "leaderboard[0].equity": "125000.00",
          "leaderboard[0].pnlPercent": "0.3654"
        },
        "discovered_at": "2024-01-15T00:00:00Z"
      }
    ]
  }
}
