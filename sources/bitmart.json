          "data.list[0].win_rate": 0.63,
          "data.list[0].max_drawdown": 0.21,
          "data.list[0].trade_count": 145,
          "data.list[0].follower_count": 310
        },
        "discovered_at": "2024-01-15T00:00:00Z"
      }
    ]
  }
}
