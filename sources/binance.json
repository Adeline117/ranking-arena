  "futures": {
    "leaderboard_endpoints": [
      {
        "method": "POST",
        "url": "https://www.binance.com/bapi/futures/v3/public/future/leaderboard/getLeaderboardRank",
        "type": "api",
        "body": {
          "isShared": true,
          "isTrader": false,
          "periodType": "MONTHLY",
          "statisticsType": "ROI",
          "tradeType": "PERPETUAL"
        },
        "notes": "periodType: WEEKLY=7d, MONTHLY=30d, QUARTERLY=90d. statisticsType: ROI|PNL. tradeType: PERPETUAL"
      },
      {
        "url": "https://www.binance.com/bapi/futures/v1/friendly/future/copy-trade/home-page/query-list",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.binance.com",
          "Referer": "https://www.binance.com/en/copy-trading",
          "Content-Type": "application/json"
        },
        "body_template": {
          "pageNumber": 1,
          "pageSize": 20,
          "timeRange": "WEEKLY",
          "dataType": "ROI",
          "favoriteOnly": false,
          "hideFull": false,
          "nickname": "",
          "order": "DESC"
        },
        "pagination": {
          "type": "page",
          "page_size": 20,
          "max_pages": 5,
          "param_name": "pageNumber"
        },
        "response_path": "data.list",
        "window_param": "timeRange",
        "sort_param": "dataType",
        "notes": "Copy trading leaderboard endpoint"
      }
    ],
    "profile_endpoints": [
      {
        "method": "POST",
        "url": "https://www.binance.com/bapi/futures/v2/public/future/leaderboard/getOtherLeaderboardBaseInfo",
        "type": "api",
        "body": {
          "encryptedUid": "{trader_key}"
        }
      },
      {
        "method": "POST",
        "url": "https://www.binance.com/bapi/futures/v1/public/future/leaderboard/getOtherPerformance",
        "type": "api",
        "body": {
          "encryptedUid": "{trader_key}",
          "tradeType": "PERPETUAL"
        }
      },
      {
        "url": "https://www.binance.com/bapi/futures/v1/public/future/copy-trade/lead-portfolio/detail",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.binance.com",
          "Content-Type": "application/json"
        },
        "body_template": {
          "portfolioId": ""
        },
        "response_path": "data"
      },
      {
        "url": "https://www.binance.com/bapi/futures/v1/public/future/copy-trade/lead-portfolio/performance",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.binance.com",
          "Content-Type": "application/json"
        },
        "body_template": {
          "portfolioId": "",
          "timeRange": "WEEKLY"
        },
        "response_path": "data"
      }
    ],
    "trader_key_field": "encryptedUid",
    "roi_sort_supported": true,
    "roi_sort_mechanism": "platform_native",
    "roi_sort_param": "statisticsType=ROI (response pre-sorted DESC)",
    "window_support": {
      "7d": { "supported": true, "param": "periodType=WEEKLY" },
      "30d": { "supported": true, "param": "periodType=MONTHLY" },
      "90d": { "supported": true, "param": "periodType=QUARTERLY" }
    },
    "field_map": {
      "encryptedUid": "trader_key",
      "nickName": "display_name",
      "userPhotoUrl": "avatar_url",
      "roi": "roi (decimal, multiply by 100)",
      "pnl": "pnl (USD)",
      "rank": "platform_rank",
      "followerCount": "followers",
      "copyCount": "copiers",
      "winRate": "win_rate",
      "maxDrawdown": "max_drawdown",
      "tradeCount": "trades_count",
      "copierCount": "copiers (alt)",
      "sharpeRatio": "sharpe_ratio",
      "totalMarginBalance": "aum"
    },
    "timeseries_endpoints": [
      {
        "method": "POST",
        "url": "https://www.binance.com/bapi/futures/v1/public/future/leaderboard/getOtherPerformance",
        "notes": "Returns daily ROI/PnL array in performanceRetList"
      }
    ],
    "rate_limits": {
      "estimated_rpm": 20,
      "cloudflare_protected": true,
      "notes": "Aggressive rate limiting, CF challenge on high frequency"
    },
    "anti_scraping": {
      "cloudflare": true,
