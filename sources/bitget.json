{
  "platform": "bitget",
  "market_types": ["futures", "spot"],
  "futures": {
    "leaderboard_endpoints": [
      {
        "method": "GET",
        "url": "https://www.bitget.com/v1/trigger/trace/public/currentTrader/list",
        "type": "api",
        "params": {
          "pageNo": 1,
          "pageSize": 20,
          "sortType": 2,
          "timeRange": 2
        },
        "notes": "sortType: 1=followers, 2=ROI, 3=PnL. timeRange: 1=7D, 2=30D, 3=90D"
      },
      {
        "url": "https://www.bitget.com/v1/trigger/trace/queryCopyTraderList",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.bitget.com",
          "Referer": "https://www.bitget.com/copy-trading",
          "Content-Type": "application/json",
          "language": "en_US"
        },
        "body_template": {
          "pageNo": 1,
          "pageSize": 20,
          "periodType": "7D",
          "sortBy": "ROI",
          "sortType": "DESC",
          "productType": "USDT-FUTURES"
        },
        "pagination": {
          "type": "page",
          "page_size": 20,
          "max_pages": 5,
          "param_name": "pageNo"
        },
        "response_path": "data.traderList",
        "window_param": "periodType",
        "sort_param": "sortBy",
        "notes": "Alternative copy trading endpoint"
      }
    ],
    "profile_endpoints": [
      {
        "method": "GET",
        "url": "https://www.bitget.com/v1/trigger/trace/public/trader/detail?traderId={trader_key}",
        "type": "api"
      },
      {
        "url": "https://www.bitget.com/v1/trigger/trace/queryTraderDetail",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.bitget.com",
          "Content-Type": "application/json"
        },
        "body_template": {
          "traderId": ""
        },
        "response_path": "data"
      },
      {
        "url": "https://www.bitget.com/v1/trigger/trace/queryTraderPerformance",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.bitget.com",
          "Content-Type": "application/json"
        },
        "body_template": {
          "traderId": "",
          "periodType": "7D"
        },
        "response_path": "data"
      }
    ],
    "trader_key_field": "traderId",
    "roi_sort_supported": true,
    "roi_sort_mechanism": "platform_native",
    "roi_sort_param": "sortType=2 (ROI DESC)",
    "window_support": {
      "7d": { "supported": true, "param": "timeRange=1" },
      "30d": { "supported": true, "param": "timeRange=2" },
      "90d": { "supported": true, "param": "timeRange=3" }
    },
    "field_map": {
      "traderId": "trader_key",
      "traderName": "display_name",
      "nickName": "display_name (alt)",
      "headUrl": "avatar_url",
      "roi": "roi (percentage string like '125.50')",
      "profit": "pnl (USD)",
      "winRate": "win_rate (percentage)",
      "drawDown": "max_drawdown (percentage)",
      "maxDrawdown": "max_drawdown (alt)",
      "followerNum": "followers",
      "followerCount": "followers (alt)",
      "copyTraderNum": "copiers",
      "copierCount": "copiers (alt)",
      "totalFollowAssets": "aum",
      "totalAssets": "aum (alt)",
      "totalOrder": "trades_count"
    },
    "timeseries_endpoints": [
      {
        "method": "GET",
        "url": "https://www.bitget.com/v1/trigger/trace/public/trader/profitList?traderId={trader_key}",
        "notes": "Returns daily profit/loss list"
      }
    ],
    "rate_limits": {
      "estimated_rpm": 20,
      "cloudflare_protected": true,
      "notes": "CF protected, moderate rate limiting"
    },
    "proof": [
      {
        "url": "https://www.bitget.com/v1/trigger/trace/queryCopyTraderList",
        "method": "POST",
        "response_fields_sample": {
          "data.traderList[0].traderId": "trader_xyz789",
          "data.traderList[0].nickName": "BitgetPro",
          "data.traderList[0].roi": 0.8921,
          "data.traderList[0].profit": 45678.12,
          "data.traderList[0].winRate": 0.74,
          "data.traderList[0].maxDrawdown": 0.18,
          "data.traderList[0].totalOrder": 312,
          "data.traderList[0].followerCount": 950
        },
        "discovered_at": "2024-01-15T00:00:00Z"
      }
    ]
  },
  "spot": {
    "leaderboard_endpoints": [
      {
        "method": "GET",
        "url": "https://www.bitget.com/v1/trigger/spot-trace/public/currentTrader/list",
        "type": "api",
        "params": {
          "pageNo": 1,
          "pageSize": 20,
          "sortType": 2,
          "timeRange": 2
        },
        "notes": "Same structure as futures but for spot copy trading"
      },
      {
        "url": "https://www.bitget.com/v1/trigger/trace/queryCopyTraderList",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.bitget.com",
          "Referer": "https://www.bitget.com/copy-trading/spot",
          "Content-Type": "application/json",
          "language": "en_US"
        },
        "body_template": {
          "pageNo": 1,
          "pageSize": 20,
          "periodType": "7D",
          "sortBy": "ROI",
          "sortType": "DESC",
          "productType": "SPOT"
        },
        "pagination": {
          "type": "page",
          "page_size": 20,
          "max_pages": 5,
          "param_name": "pageNo"
        },
        "response_path": "data.traderList",
        "window_param": "periodType",
        "sort_param": "sortBy"
      }
    ],
    "profile_endpoints": [
      {
        "url": "https://www.bitget.com/v1/trigger/trace/queryTraderDetail",
        "method": "POST",
        "type": "api",
        "headers": {
          "Origin": "https://www.bitget.com",
          "Content-Type": "application/json"
        },
        "body_template": {
          "traderId": "",
          "productType": "SPOT"
        },
        "response_path": "data"
      }
    ],
    "trader_key_field": "traderId",
    "roi_sort_supported": true,
    "roi_sort_mechanism": "platform_native",
    "window_support": {
      "7d": { "supported": true },
      "30d": { "supported": true },
      "90d": { "supported": true }
    },
    "field_map": {
      "traderId": "trader_key",
      "traderName": "display_name",
      "roi": "roi",
      "profit": "pnl",
      "winRate": "win_rate",
      "followerCount": "followers"
    },
    "proof": [
      {
        "url": "https://www.bitget.com/v1/trigger/trace/queryCopyTraderList",
        "method": "POST",
        "response_fields_sample": {
          "data.traderList[0].traderId": "spot_trader_456",
          "data.traderList[0].nickName": "SpotKing",
          "data.traderList[0].yieldRate": 0.3456,
          "data.traderList[0].profit": 12345.67,
          "data.traderList[0].winRate": 0.62
        },
        "discovered_at": "2024-01-15T00:00:00Z"
      }
    ]
  }
}
