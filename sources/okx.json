{
  "platform": "okx",
  "market_types": ["futures", "copy", "web3"],
  "futures": {
    "leaderboard_endpoints": [
      {
        "method": "GET",
        "url": "https://www.okx.com/priapi/v5/ecotrade/public/trader-list",
        "type": "api",
        "params": {
          "sortType": "profitRatio",
          "dataRange": "30",
          "pageNo": "1",
          "pageSize": "20"
        },
        "notes": "sortType: profitRatio=ROI, profit=PnL. dataRange: 7, 30, 90"
      },
      {
        "url": "https://www.okx.com/priapi/v5/ecotrade/public/leader-board",
        "method": "GET",
        "type": "api",
        "headers": {
          "Referer": "https://www.okx.com/copy-trading/leaderboard",
          "Origin": "https://www.okx.com"
        },
        "query_params": {
          "pageNo": "1",
          "pageSize": "20",
          "sortField": "pnlRatio",
          "sortType": "desc",
          "period": "7D"
        },
        "pagination": {
          "type": "page",
          "page_size": 20,
          "max_pages": 5,
          "param_name": "pageNo"
        },
        "response_path": "data.ranks",
        "window_param": "period",
        "sort_param": "sortField",
        "notes": "Alternative leaderboard endpoint"
      }
    ],
    "profile_endpoints": [
      {
        "method": "GET",
        "url": "https://www.okx.com/priapi/v5/ecotrade/public/trader-detail?uniqueName={trader_key}",
        "type": "api"
      },
      {
        "method": "GET",
        "url": "https://www.okx.com/priapi/v5/ecotrade/public/profit-detail?uniqueName={trader_key}&dataRange=90",
        "type": "api",
        "notes": "Performance details with daily PnL"
      }
    ],
    "trader_key_field": "uniqueName",
    "roi_sort_supported": true,
    "roi_sort_mechanism": "platform_native",
    "roi_sort_param": "sortType=profitRatio (returns DESC sorted)",
    "window_support": {
      "7d": { "supported": true, "param": "dataRange=7" },
      "30d": { "supported": true, "param": "dataRange=30" },
      "90d": { "supported": true, "param": "dataRange=90" }
    },
    "field_map": {
      "uniqueName": "trader_key",
      "nickName": "display_name",
      "portrait": "avatar_url",
      "profitRatio": "roi (decimal, multiply by 100)",
      "pnlRatio": "roi (alt, decimal)",
      "profit": "pnl (USD)",
      "pnl": "pnl (alt)",
      "winRatio": "win_rate (decimal)",
      "winRate": "win_rate (alt)",
      "maxDrawdown": "max_drawdown (decimal, negate)",
      "followerNum": "followers",
      "followerCount": "followers (alt)",
      "copyTraderNum": "copiers",
      "copierCount": "copiers (alt)",
      "aum": "aum",
      "orderCount": "trades_count"
    },
    "timeseries_endpoints": [
      {
        "method": "GET",
        "url": "https://www.okx.com/priapi/v5/ecotrade/public/profit-detail?uniqueName={trader_key}&dataRange=90",
        "notes": "Returns daily profit list with timestamps"
      }
    ],
    "rate_limits": {
      "estimated_rpm": 20,
