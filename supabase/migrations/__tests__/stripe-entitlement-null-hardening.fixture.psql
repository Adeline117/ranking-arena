SELECT pg_catalog.set_config(
  'request.jwt.claim.role',
  'service_role',
  false
);

CREATE OR REPLACE FUNCTION pg_temp.stripe_null_hardening_snapshot()
RETURNS jsonb
LANGUAGE sql
SET search_path = pg_catalog, pg_temp
AS $function$
  SELECT pg_catalog.jsonb_build_object(
    'profiles',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.user_profiles AS row_value
    ),
    'subscriptions',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.subscriptions AS row_value
    ),
    'payment_history',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.payment_history AS row_value
    ),
    'payments',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_entitlement_payments AS row_value
    ),
    'charge_tombstones',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_charge_refund_tombstones AS row_value
    ),
    'charge_tombstone_events',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_charge_refund_tombstone_events AS row_value
    ),
    'reservations',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_lifetime_seat_reservations AS row_value
    ),
    'legacy_claims',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_legacy_lifetime_seat_claims AS row_value
    ),
    'trials',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_trial_entitlements AS row_value
    ),
    'subscription_events',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_subscription_state_events AS row_value
    ),
    'grants',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.pro_entitlement_grants AS row_value
    ),
    'reviews',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_manual_reviews AS row_value
    ),
    'refund_events',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_entitlement_refund_events AS row_value
    ),
    'effects',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.stripe_entitlement_effects AS row_value
    ),
    'official_members',
    (
      SELECT COALESCE(
        pg_catalog.jsonb_agg(
          pg_catalog.to_jsonb(row_value)
          ORDER BY pg_catalog.to_jsonb(row_value)::text
        ),
        '[]'::jsonb
      )
      FROM public.test_official_members AS row_value
    )
  )
$function$;

DO $null_business_input_proof$
DECLARE
  v_before jsonb := pg_temp.stripe_null_hardening_snapshot();
  v_after jsonb;
  v_case record;
  v_rejected integer := 0;
BEGIN
  FOR v_case IN
    SELECT *
    FROM (
      VALUES
        (
          'refund tombstone state',
          $statement$
            SELECT public.record_charge_refund_tombstone_atomic(
              NULL,
              'cus_null_tombstone',
              NULL,
              'ch_null_tombstone',
              true,
              1000,
              'usd',
              500,
              NULL,
              'evt_null_tombstone',
              '2035-01-01Z'
            )
          $statement$
        ),
        (
          'reservation release reason',
          $statement$
            SELECT public.release_lifetime_membership_reservation_atomic(
              'f1000000-0000-0000-0000-000000000001',
              'f2000000-0000-0000-0000-000000000001',
              'null-release-reason',
              NULL,
              NULL,
              NULL,
              NULL
            )
          $statement$
        ),
        (
          'recurring activation plan',
          $statement$
            SELECT public.activate_recurring_entitlement_payment_atomic(
              'f1000000-0000-0000-0000-000000000002',
              'cus_null_recurring_plan',
              'sub_null_recurring_plan',
              'in_null_recurring_plan',
              'pi_null_recurring_plan',
              'ch_null_recurring_plan',
              NULL,
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              'paid',
              'active'
            )
          $statement$
        ),
        (
          'recurring activation payment status',
          $statement$
            SELECT public.activate_recurring_entitlement_payment_atomic(
              'f1000000-0000-0000-0000-000000000003',
              'cus_null_payment_status',
              'sub_null_payment_status',
              'in_null_payment_status',
              'pi_null_payment_status',
              'ch_null_payment_status',
              'monthly',
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              NULL,
              'active'
            )
          $statement$
        ),
        (
          'recurring activation subscription status',
          $statement$
            SELECT public.activate_recurring_entitlement_payment_atomic(
              'f1000000-0000-0000-0000-000000000004',
              'cus_null_activation_status',
              'sub_null_activation_status',
              'in_null_activation_status',
              'pi_null_activation_status',
              'ch_null_activation_status',
              'monthly',
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              'paid',
              NULL
            )
          $statement$
        ),
        (
          'trial activation plan',
          $statement$
            SELECT public.activate_recurring_trial_entitlement_atomic(
              'f1000000-0000-0000-0000-000000000005',
              'cus_null_trial_plan',
              'sub_null_trial_plan',
              NULL,
              '2035-01-01Z',
              '2035-02-01Z',
              'trialing'
            )
          $statement$
        ),
        (
          'subscription state plan',
          $statement$
            SELECT public.reconcile_recurring_subscription_state_atomic(
              'f1000000-0000-0000-0000-000000000006',
              'cus_null_state_plan',
              'sub_null_state_plan',
              NULL,
              NULL,
              '2035-01-01Z',
              '2035-02-01Z',
              'active',
              false,
              NULL,
              NULL,
              'evt_null_state_plan',
              '2035-01-02Z'
            )
          $statement$
        ),
        (
          'subscription state Stripe status',
          $statement$
            SELECT public.reconcile_recurring_subscription_state_atomic(
              'f1000000-0000-0000-0000-000000000007',
              'cus_null_state_status',
              'sub_null_state_status',
              NULL,
              'monthly',
              '2035-01-01Z',
              '2035-02-01Z',
              NULL,
              false,
              NULL,
              NULL,
              'evt_null_state_status',
              '2035-01-02Z'
            )
          $statement$
        ),
        (
          'refund payment kind',
          $statement$
            SELECT public.reconcile_stripe_entitlement_refund_atomic(
              NULL,
              'cus_null_refund_kind',
              NULL,
              'monthly',
              'sub_null_refund_kind',
              'in_null_refund_kind',
              'pi_null_refund_kind',
              'ch_null_refund_kind',
              NULL,
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              'paid',
              500,
              'pending',
              'active',
              'evt_null_refund_kind',
              '2035-01-02Z'
            )
          $statement$
        ),
        (
          'refund payment status',
          $statement$
            SELECT public.reconcile_stripe_entitlement_refund_atomic(
              NULL,
              'cus_null_refund_payment',
              'recurring',
              'monthly',
              'sub_null_refund_payment',
              'in_null_refund_payment',
              'pi_null_refund_payment',
              'ch_null_refund_payment',
              NULL,
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              NULL,
              500,
              'pending',
              'active',
              'evt_null_refund_payment',
              '2035-01-02Z'
            )
          $statement$
        ),
        (
          'refund state',
          $statement$
            SELECT public.reconcile_stripe_entitlement_refund_atomic(
              NULL,
              'cus_null_refund_state',
              'recurring',
              'monthly',
              'sub_null_refund_state',
              'in_null_refund_state',
              'pi_null_refund_state',
              'ch_null_refund_state',
              NULL,
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              'paid',
              500,
              NULL,
              'active',
              'evt_null_refund_state',
              '2035-01-02Z'
            )
          $statement$
        ),
        (
          'recurring refund plan',
          $statement$
            SELECT public.reconcile_stripe_entitlement_refund_atomic(
              NULL,
              'cus_null_refund_plan',
              'recurring',
              NULL,
              'sub_null_refund_plan',
              'in_null_refund_plan',
              'pi_null_refund_plan',
              'ch_null_refund_plan',
              NULL,
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              'paid',
              500,
              'pending',
              'active',
              'evt_null_refund_plan',
              '2035-01-02Z'
            )
          $statement$
        ),
        (
          'recurring refund subscription status',
          $statement$
            SELECT public.reconcile_stripe_entitlement_refund_atomic(
              NULL,
              'cus_null_refund_substatus',
              'recurring',
              'monthly',
              'sub_null_refund_substatus',
              'in_null_refund_substatus',
              'pi_null_refund_substatus',
              'ch_null_refund_substatus',
              NULL,
              1000,
              'usd',
              '2035-01-01Z',
              '2035-02-01Z',
              'paid',
              500,
              'pending',
              NULL,
              'evt_null_refund_substatus',
              '2035-01-02Z'
            )
          $statement$
        )
    ) AS test_case(case_name, statement)
  LOOP
    BEGIN
      EXECUTE v_case.statement;
      RAISE EXCEPTION
        'NULL business input was accepted: %',
        v_case.case_name;
    EXCEPTION
      WHEN invalid_parameter_value THEN
        v_rejected := v_rejected + 1;
    END;
  END LOOP;

  IF v_rejected IS DISTINCT FROM 13 THEN
    RAISE EXCEPTION
      'expected 13 NULL business-input rejections, observed %',
      v_rejected;
  END IF;

  v_after := pg_temp.stripe_null_hardening_snapshot();
  IF v_after IS DISTINCT FROM v_before THEN
    RAISE EXCEPTION
      'NULL enum/status validation changed Stripe entitlement state';
  END IF;
END
$null_business_input_proof$;

