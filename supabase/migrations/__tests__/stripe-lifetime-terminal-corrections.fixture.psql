DO $hard_deleted_cancel_effect_remains_financially_actionable$
DECLARE
  v_user_id uuid := '00000000-0000-0000-0000-000000000967';
  v_status text;
  v_effect_id uuid;
  v_payment_id uuid;
  v_lease_token uuid;
BEGIN
  PERFORM pg_catalog.set_config(
    'request.jwt.claim.role',
    'service_role',
    true
  );

  v_status := public.test_activate_recurring(
    v_user_id,
    'sub_cancel_deleted_967',
    'cancel_deleted_original_967',
    pg_catalog.statement_timestamp() - pg_catalog.make_interval(days => 1),
    pg_catalog.statement_timestamp() + pg_catalog.make_interval(days => 30)
  ) ->> 'status';
  IF v_status IS DISTINCT FROM 'activated' THEN
    RAISE EXCEPTION 'deleted cancel recurring setup failed: %', v_status;
  END IF;

  v_status := public.test_activate_lifetime(
    v_user_id,
    'lifetime_cancel_deleted_967',
    pg_catalog.statement_timestamp() - pg_catalog.make_interval(hours => 1)
  ) ->> 'status';
  IF v_status IS DISTINCT FROM 'activated' THEN
    RAISE EXCEPTION 'deleted cancel lifetime setup failed: %', v_status;
  END IF;

  SELECT effect.id, effect.entitlement_payment_id
  INTO v_effect_id, v_payment_id
  FROM public.stripe_entitlement_effects AS effect
  WHERE effect.user_id = v_user_id
    AND effect.effect_type = 'stripe_subscription_cancel';

  DELETE FROM auth.users AS auth_user
  WHERE auth_user.id = v_user_id;

  IF (
      SELECT effect.user_id
      FROM public.stripe_entitlement_effects AS effect
      WHERE effect.id = v_effect_id
    ) IS NOT NULL
    OR (
      SELECT payment.user_id
      FROM public.stripe_entitlement_payments AS payment
      WHERE payment.id = v_payment_id
    ) IS NOT NULL
    OR EXISTS (
      SELECT 1
      FROM public.subscriptions AS subscription
      WHERE subscription.entitlement_payment_id = v_payment_id
    )
    OR NOT public.stripe_entitlement_effect_is_current_v2(v_effect_id)
  THEN
    RAISE EXCEPTION
      'hard-delete cancellation fixture did not retain exact financial authority';
  END IF;

  UPDATE public.stripe_entitlement_effects
  SET status = 'superseded',
      lease_token = NULL,
      lease_expires_at = NULL,
      completed_at = pg_catalog.clock_timestamp(),
      updated_at = pg_catalog.clock_timestamp()
  WHERE id IS DISTINCT FROM v_effect_id
    AND status IN ('pending', 'failed');
  UPDATE public.stripe_entitlement_effects
  SET available_at =
        pg_catalog.statement_timestamp() - pg_catalog.make_interval(secs => 1)
  WHERE id = v_effect_id;

  SELECT leased_effect.lease_token
  INTO v_lease_token
  FROM public.lease_stripe_entitlement_effects_atomic(100, 300)
    AS leased_effect
  WHERE leased_effect.id = v_effect_id;

  IF v_lease_token IS NULL
    OR public.finish_stripe_entitlement_effect_atomic(
      v_effect_id,
      v_lease_token,
      true,
      'sub_cancel_deleted_967',
      NULL,
      NULL
    ) ->> 'status' IS DISTINCT FROM 'completed'
  THEN
    RAISE EXCEPTION
      'hard-deleted recurring cancellation was not financially actionable';
  END IF;
END
$hard_deleted_cancel_effect_remains_financially_actionable$;

DO $cancel_effect_payload_and_operation_are_exact$
DECLARE
  v_user_id uuid := '00000000-0000-0000-0000-000000000968';
  v_status text;
  v_effect_id uuid;
  v_payload jsonb;
  v_operation_key text;
  v_paid_at timestamptz :=
    pg_catalog.statement_timestamp() - pg_catalog.make_interval(hours => 1);
  v_lease_token uuid;
BEGIN
  PERFORM pg_catalog.set_config(
    'request.jwt.claim.role',
    'service_role',
    true
  );

  v_status := public.test_activate_recurring(
    v_user_id,
    'sub_cancel_payload_968',
    'cancel_payload_original_968',
    pg_catalog.statement_timestamp() - pg_catalog.make_interval(days => 1),
    pg_catalog.statement_timestamp() + pg_catalog.make_interval(days => 30)
  ) ->> 'status';
  IF v_status IS DISTINCT FROM 'activated' THEN
    RAISE EXCEPTION 'payload cancel recurring setup failed: %', v_status;
  END IF;

  v_status := public.test_activate_lifetime(
    v_user_id,
    'lifetime_cancel_payload_968',
    v_paid_at
  ) ->> 'status';
  IF v_status IS DISTINCT FROM 'activated' THEN
    RAISE EXCEPTION 'payload cancel lifetime setup failed: %', v_status;
  END IF;

  SELECT effect.id, effect.payload, effect.operation_key
  INTO v_effect_id, v_payload, v_operation_key
  FROM public.stripe_entitlement_effects AS effect
  WHERE effect.user_id = v_user_id
    AND effect.effect_type = 'stripe_subscription_cancel';

  IF NOT public.stripe_entitlement_effect_is_current_v2(v_effect_id) THEN
    RAISE EXCEPTION 'exact cancellation payload was not current';
  END IF;

  UPDATE public.stripe_entitlement_effects
  SET payload = pg_catalog.jsonb_set(
    payload,
    '{stripe_customer_id}',
    '"cus_wrong_payload_968"'::jsonb
  )
  WHERE id = v_effect_id;
  IF public.stripe_entitlement_effect_is_current_v2(v_effect_id) THEN
    RAISE EXCEPTION 'wrong cancellation customer payload remained current';
  END IF;

  UPDATE public.stripe_entitlement_effects
  SET payload = v_payload,
      operation_key = 'cancel:subscription:sub_wrong_operation_968'
  WHERE id = v_effect_id;
  IF public.stripe_entitlement_effect_is_current_v2(v_effect_id) THEN
    RAISE EXCEPTION 'wrong cancellation operation remained current';
  END IF;

  UPDATE public.stripe_entitlement_effects
  SET operation_key = v_operation_key,
      payload = pg_catalog.jsonb_set(
        v_payload,
        '{stripe_subscription_id}',
        '"sub_wrong_payload_968"'::jsonb
      )
  WHERE id = v_effect_id;
  IF public.stripe_entitlement_effect_is_current_v2(v_effect_id) THEN
    RAISE EXCEPTION 'wrong cancellation subscription payload remained current';
  END IF;

  UPDATE public.stripe_entitlement_effects
  SET operation_key = v_operation_key,
      payload = v_payload
  WHERE id = v_effect_id;

  v_status := public.test_refund_lifetime(
    v_user_id,
    'lifetime_cancel_payload_968',
    50000,
    'succeeded',
    'evt_refund_lifetime_cancel_968',
    pg_catalog.statement_timestamp(),
    v_paid_at
  ) ->> 'status';
  IF v_status IS NULL THEN
    RAISE EXCEPTION 'payload cancellation refund setup failed';
  END IF;

  UPDATE public.stripe_entitlement_effects
  SET status = 'superseded',
      lease_token = NULL,
      lease_expires_at = NULL,
      completed_at = pg_catalog.clock_timestamp(),
      updated_at = pg_catalog.clock_timestamp()
  WHERE id IS DISTINCT FROM v_effect_id
    AND status IN ('pending', 'failed');
  UPDATE public.stripe_entitlement_effects
  SET available_at =
        pg_catalog.statement_timestamp() - pg_catalog.make_interval(secs => 1)
  WHERE id = v_effect_id;

  SELECT leased_effect.lease_token
  INTO v_lease_token
  FROM public.lease_stripe_entitlement_effects_atomic(100, 300)
    AS leased_effect
  WHERE leased_effect.id = v_effect_id;
  IF v_lease_token IS NOT NULL
    OR (
      SELECT effect.status
      FROM public.stripe_entitlement_effects AS effect
      WHERE effect.id = v_effect_id
    ) IS DISTINCT FROM 'superseded'
  THEN
    RAISE EXCEPTION
      'full lifetime refund was leased for remote cancellation';
  END IF;
END
$cancel_effect_payload_and_operation_are_exact$;

\echo 'Stripe lifetime terminal corrections fixture passed'
