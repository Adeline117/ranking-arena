DO $production_fk_trigger_order_matches$
DECLARE
  v_notification_parent_trigger_max oid;
  v_tip_parent_trigger_min oid;
BEGIN
  SELECT pg_catalog.max(trigger.oid)
  INTO v_notification_parent_trigger_max
  FROM pg_catalog.pg_trigger AS trigger
  JOIN pg_catalog.pg_constraint AS constraint_row
    ON constraint_row.oid = trigger.tgconstraint
  WHERE trigger.tgrelid = 'auth.users'::pg_catalog.regclass
    AND constraint_row.conname IN (
      'notifications_user_id_fkey',
      'notifications_actor_id_fkey'
    );

  SELECT pg_catalog.min(trigger.oid)
  INTO v_tip_parent_trigger_min
  FROM pg_catalog.pg_trigger AS trigger
  JOIN pg_catalog.pg_constraint AS constraint_row
    ON constraint_row.oid = trigger.tgconstraint
  WHERE trigger.tgrelid = 'auth.users'::pg_catalog.regclass
    AND constraint_row.conname IN (
      'tips_from_user_id_fkey',
      'tips_to_user_id_fkey'
    );

  IF v_notification_parent_trigger_max IS NULL
    OR v_tip_parent_trigger_min IS NULL
    OR v_notification_parent_trigger_max >= v_tip_parent_trigger_min
  THEN
    RAISE EXCEPTION
      'fixture does not match production notification-before-tip FK order: notification %, tip %',
      v_notification_parent_trigger_max,
      v_tip_parent_trigger_min;
  END IF;
END
$production_fk_trigger_order_matches$;

