DO $first_completion_and_replay$
DECLARE
  v_tip_id uuid := 'd3000000-0000-4000-8000-000000000001';
  v_first jsonb;
  v_replay jsonb;
BEGIN
  INSERT INTO public.tips (
    id,
    post_id,
    from_user_id,
    to_user_id,
    amount_cents,
    status,
    stripe_checkout_session_id
  ) VALUES (
    v_tip_id,
    'd2000000-0000-4000-8000-000000000001',
    'd1000000-0000-4000-8000-000000000001',
    'd1000000-0000-4000-8000-000000000002',
    1234,
    'pending',
    'cs_durable_tip_first'
  );

  v_first := public.complete_tip_with_stripe_ownership_atomic(
    v_tip_id,
    'cus_durable_tip_actor',
    'pi_durable_tip_first',
    'ch_durable_tip_first',
    'cs_durable_tip_first',
    1234,
    'usd',
    '2036-01-01 00:00:00+00'
  );
  IF v_first ->> 'status' <> 'completed'
    OR v_first ->> 'tombstone_status' <> 'no_tombstone'
  THEN
    RAISE EXCEPTION 'first tip completion failed: %', v_first;
  END IF;

  IF (
    SELECT pg_catalog.count(*)
    FROM public.notifications AS notification
    WHERE notification.type = 'tip_received'
      AND notification.reference_id = v_tip_id
      AND notification.user_id =
        'd1000000-0000-4000-8000-000000000002'
      AND notification.actor_id =
        'd1000000-0000-4000-8000-000000000001'
      AND notification.title = '收到打赏'
      AND notification.message = '你的帖子收到了一笔 $12.34 打赏'
      AND notification.link =
        '/post/d2000000-0000-4000-8000-000000000001'
  ) <> 1 OR NOT EXISTS (
    SELECT 1
    FROM public.tip_completion_notification_deliveries AS delivery
    WHERE delivery.tip_id = v_tip_id
      AND delivery.payload_spec = 'tip_completion_v1'
      AND delivery.disposition = 'delivered'
      AND delivery.notification_id IS NOT NULL
      AND delivery.delivered_at IS NOT NULL
      AND delivery.disposed_at IS NULL
  ) OR NOT EXISTS (
    SELECT 1
    FROM public.stripe_payment_ownerships AS ownership
    WHERE ownership.product_kind = 'tip'
      AND ownership.ledger_id = v_tip_id
      AND public.stripe_payment_ownership_is_exact_v2(ownership.id)
  ) THEN
    RAISE EXCEPTION 'first tip delivery was not exact';
  END IF;

  v_replay := public.complete_tip_with_stripe_ownership_atomic(
    v_tip_id,
    'cus_durable_tip_actor',
    'pi_durable_tip_first',
    'ch_durable_tip_first',
    'cs_durable_tip_first',
    1234,
    'usd',
    '2036-01-01 00:00:00+00'
  );
  IF v_replay ->> 'status' <> 'already_completed'
    OR (
      SELECT pg_catalog.count(*)
      FROM public.notifications AS notification
      WHERE notification.type = 'tip_received'
        AND notification.reference_id = v_tip_id
    ) <> 1
    OR (
      SELECT pg_catalog.count(*)
      FROM public.tip_completion_notification_deliveries AS delivery
      WHERE delivery.tip_id = v_tip_id
    ) <> 1
  THEN
    RAISE EXCEPTION 'tip completion replay was not idempotent: %', v_replay;
  END IF;
END
$first_completion_and_replay$;

-- Identity fields cannot be edited, but normal read state remains mutable.
UPDATE public.notifications
SET read = true,
    read_at = '2036-01-01 00:01:00+00'
WHERE type = 'tip_received'
  AND reference_id = 'd3000000-0000-4000-8000-000000000001';

DO $notification_identity_is_immutable$
BEGIN
  BEGIN
    UPDATE public.notifications
    SET title = 'forged'
    WHERE type = 'tip_received'
      AND reference_id = 'd3000000-0000-4000-8000-000000000001';
    RAISE EXCEPTION 'tip notification title mutation unexpectedly succeeded';
  EXCEPTION
    WHEN check_violation THEN
      IF SQLERRM <> 'tip_received notification identity is immutable' THEN
        RAISE;
      END IF;
  END;
END
$notification_identity_is_immutable$;

-- Exercise the real recipient DELETE policy/role. The after-delete trigger
-- persists a tombstone even though the inbox row is intentionally gone.
RESET ROLE;
SET ROLE authenticated;
SELECT pg_catalog.set_config(
  'request.jwt.claim.sub',
  'd1000000-0000-4000-8000-000000000002',
  false
);
DELETE FROM public.notifications
WHERE type = 'tip_received'
  AND reference_id = 'd3000000-0000-4000-8000-000000000001';
RESET ROLE;
SELECT pg_catalog.set_config(
  'request.jwt.claim.role',
  'service_role',
  false
);

DO $deleted_notification_replay_does_not_resurrect$
DECLARE
  v_result jsonb;
BEGIN
  IF NOT EXISTS (
    SELECT 1
    FROM public.tip_completion_notification_deliveries AS delivery
    WHERE delivery.tip_id =
        'd3000000-0000-4000-8000-000000000001'
      AND delivery.disposition = 'recipient_deleted'
      AND delivery.disposed_at IS NOT NULL
  ) THEN
    RAISE EXCEPTION 'recipient deletion did not persist a tombstone';
  END IF;

  v_result := public.complete_tip_with_stripe_ownership_atomic(
    'd3000000-0000-4000-8000-000000000001',
    'cus_durable_tip_actor',
    'pi_durable_tip_first',
    'ch_durable_tip_first',
    'cs_durable_tip_first',
    1234,
    'usd',
    '2036-01-01 00:00:00+00'
  );
  IF v_result ->> 'status' <> 'already_completed'
    OR EXISTS (
      SELECT 1
      FROM public.notifications AS notification
      WHERE notification.type = 'tip_received'
        AND notification.reference_id =
          'd3000000-0000-4000-8000-000000000001'
    )
  THEN
    RAISE EXCEPTION 'deleted notification was resurrected: %', v_result;
  END IF;
END
$deleted_notification_replay_does_not_resurrect$;

