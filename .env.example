# =============================================================================
# Ranking Arena - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# For production, set these in Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUIRED)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Stripe Payment (REQUIRED for payment features)
# -----------------------------------------------------------------------------
# Server-only: NEVER expose these to the client bundle
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Price IDs from Stripe Dashboard → Products → Prices
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxx

# Client-safe: prefixed with NEXT_PUBLIC_ for frontend Stripe.js usage
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Upstash Redis Cache (recommended, falls back to in-memory cache)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# Sentry Error Monitoring (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-auth-token

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret

# ============================================
# Cloudflare Worker 代理 (解决 IP 封禁)
# ============================================
# 部署步骤:
#   1. cd cloudflare-worker
#   2. npx wrangler login
#   3. npx wrangler deploy
#   4. 复制输出的 Worker URL 到这里
CLOUDFLARE_PROXY_URL=https://ranking-arena-proxy.<your-account>.workers.dev
# CLOUDFLARE_PROXY_SECRET=optional-secret-for-authentication

# ============================================
# Dune Analytics (链上数据)
# ============================================
# 获取 API Key:
#   1. 访问 https://dune.com
#   2. 升级到 Analyst 或 Plus 计划 (Free 无 API 访问)
#   3. Settings -> API -> Create Key
# DUNE_API_KEY=your_dune_api_key

# 可选: 自定义 Dune Query IDs
# DUNE_GMX_QUERY_ID=12345
# DUNE_HYPERLIQUID_QUERY_ID=12345
# DUNE_UNISWAP_QUERY_ID=12345

# ============================================
# The Graph Network (DEX 数据)
# ============================================
# 用于获取 Kwenta, MUX, Gains Network 等 DEX 数据
# 获取免费 API Key (100,000 查询/月):
#   1. 访问 https://thegraph.com/studio/apikeys/
#   2. 使用钱包登录
#   3. 创建 API Key
# THEGRAPH_API_KEY=your_graph_api_key

# OpenAI (翻译功能)
# OPENAI_API_KEY=sk-...

# =============================================================================
# Web3 / deSoc (Optional — enables wallet login, NFT membership, on-chain scores)
# =============================================================================

# WalletConnect Project ID (get free at https://cloud.walletconnect.com)
# Required for wallet connection modal
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Base L2 RPC URLs (defaults to public endpoints if not set)
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Contract Deployment (for deploying smart contracts)
# Create a testnet wallet, fund with Base Sepolia ETH from:
# https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
# DEPLOYER_PRIVATE_KEY=0x...

# Basescan API key for contract verification
# Get from: https://basescan.org/myapikey
# BASESCAN_API_KEY=your-basescan-api-key

# Arena Membership NFT contract address (set after deployment)
# NEXT_PUBLIC_MEMBERSHIP_NFT_ADDRESS=0x...

# EAS (Ethereum Attestation Service) — Arena Score on-chain verification
# Schema UID (set after registering the schema on Base)
# NEXT_PUBLIC_ARENA_SCORE_SCHEMA_UID=0x...
# Private key of the Arena attester wallet (server-only, never expose)
# ARENA_ATTESTER_PRIVATE_KEY=0x...

# Snapshot Governance (gasless voting)
# Create a space at https://snapshot.org, then set the space ID here
# NEXT_PUBLIC_SNAPSHOT_SPACE_ID=arena.eth
