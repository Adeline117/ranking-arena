# ==============================================
# Ranking Arena - Environment Variables
# Copy this file to .env.local and fill in values
# ==============================================

# ── Core ──
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ── Redis / Upstash ──
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Auth ──
ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com
ADMIN_SECRET=your-admin-secret
INVITE_SECRET=your-invite-secret

# ── Encryption ──
ENCRYPTION_KEY=your-encryption-key
ENCRYPTION_KEY_PART1=your-encryption-key-part1
ENCRYPTION_SALT=your-encryption-salt

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY_ID=price_xxx
STRIPE_PRICE_YEARLY_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_ELITE_PRICE_ID=price_xxx

# ── OpenAI ──
OPENAI_API_KEY=sk-xxx

# ── Email (Resend) ──
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@example.com

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALERT_CHAT_ID=your-chat-id

# ── Auth (Privy) ──
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# ── Web3 / RPC ──
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
BSC_RPC_URL=https://bsc-dataseed.binance.org
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
OPTIMISM_RPC_URL=https://mainnet.optimism.io
POLYGON_RPC_URL=https://polygon-rpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ARENA_ATTESTER_PRIVATE_KEY=0x_your_private_key
NFT_MINTER_PRIVATE_KEY=0x_your_private_key
NEXT_PUBLIC_MEMBERSHIP_NFT_ADDRESS=0x_your_contract_address
NEXT_PUBLIC_ARENA_SCORE_SCHEMA_UID=your-schema-uid
NEXT_PUBLIC_COPY_TRADING_ARBITRUM=0x_address
NEXT_PUBLIC_COPY_TRADING_BASE=0x_address
NEXT_PUBLIC_COPY_TRADING_BASE_SEPOLIA=0x_address
NEXT_PUBLIC_COPY_TRADING_OPTIMISM=0x_address
THEGRAPH_API_KEY=your-graph-key

# ── Block Explorer API Keys ──
ETHERSCAN_API_KEY=your-etherscan-key
ARBISCAN_API_KEY=your-arbiscan-key
BASESCAN_API_KEY=your-basescan-key
BSCSCAN_API_KEY=your-bscscan-key
POLYGONSCAN_API_KEY=your-polygonscan-key
OPTIMISTIC_ETHERSCAN_API_KEY=your-optimistic-etherscan-key
SNOWTRACE_API_KEY=your-snowtrace-key

# ── Exchange APIs ──
BYBIT_API_KEY=your-key
BYBIT_API_SECRET=your-secret
BYBIT_OAUTH_CLIENT_ID=your-client-id
BYBIT_OAUTH_CLIENT_SECRET=your-client-secret
BINANCE_OAUTH_CLIENT_ID=your-client-id
BINANCE_OAUTH_CLIENT_SECRET=your-client-secret
BITGET_API_KEY=your-key
BITGET_API_SECRET=your-secret
BITGET_API_PASSPHRASE=your-passphrase
GATEIO_API_KEY=your-key
GATEIO_API_SECRET=your-secret
DRIFT_API_KEY=your-key
OKX_API_KEY=your-key
OKX_API_SECRET=your-secret

# ── Cron / Workers ──
CRON_SECRET=your-cron-secret
WORKER_SECRET=your-worker-secret
WORKER_URL=http://localhost:3000
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL=60000
WORKER_PLATFORMS=bybit,binance

# ── QStash ──
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# ── Proxy ──
CLOUDFLARE_PROXY_URL=https://your-proxy.workers.dev
CLOUDFLARE_PROXY_SECRET=your-secret
STEALTH_PROXY=https://your-stealth-proxy.example.com

# ── Cloudflare R2 (Object Storage) ──
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=your-bucket-name
R2_PUBLIC_URL=https://your-r2-public.example.com

# ── Stripe (Public) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Sentry ──
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ── FCM ──
FCM_SERVER_KEY=your-fcm-key

# ── Web Push (VAPID) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Analytics ──
NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics.example.com
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Snapshot ──
NEXT_PUBLIC_SNAPSHOT_SPACE_ID=your-space-id

# ── Smart Scheduler ──
ENABLE_SMART_SCHEDULER=false
SMART_SCHEDULER_HOT_INTERVAL_MINUTES=30
SMART_SCHEDULER_ACTIVE_INTERVAL_MINUTES=60
SMART_SCHEDULER_NORMAL_INTERVAL_MINUTES=240
SMART_SCHEDULER_DORMANT_INTERVAL_MINUTES=720
SMART_SCHEDULER_HOT_RANK_THRESHOLD=50
SMART_SCHEDULER_ACTIVE_RANK_THRESHOLD=200
SMART_SCHEDULER_NORMAL_RANK_THRESHOLD=500
SMART_SCHEDULER_HOT_FOLLOWERS_THRESHOLD=100
SMART_SCHEDULER_ACTIVE_FOLLOWERS_THRESHOLD=20
SMART_SCHEDULER_HOT_VIEWS_THRESHOLD=1000
SMART_SCHEDULER_MAX_BATCH_SIZE=50
SMART_SCHEDULER_STAGGER_MS=500
SMART_SCHEDULER_TIER_RECALC_MINUTES=60

# ── Anomaly Detection ──
ENABLE_ANOMALY_DETECTION=false
ANOMALY_DETECTION_Z_SCORE_THRESHOLD=3.0
ANOMALY_DETECTION_IQR_MULTIPLIER=1.5
ANOMALY_DETECTION_MIN_SAMPLE_SIZE=10

# ── HSM ──
HSM_ENDPOINT=https://your-hsm.example.com
HSM_KEY_ID=your-key-id

# ── Internal API ──
INTERNAL_API_KEY=your-internal-api-key

# ── Groups ──
PRO_OFFICIAL_GROUP_ID=your-group-id

# ── Playwright (E2E) ──
PLAYWRIGHT_BASE_URL=http://localhost:3000
