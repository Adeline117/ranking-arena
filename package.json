{
  "name": "ranking-arena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=3584' next dev",
    "build": "next build",
    "build:webpack": "TURBOPACK=0 next build",
    "analyze": "ANALYZE=true TURBOPACK=0 next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "scrape:details": "node scripts/fetch_details_fast.mjs",
    "scrape:details:force": "node scripts/fetch_details_fast.mjs --force",
    "worker:jobs": "npx tsx worker/src/job-runner/index.ts",
    "worker:discover": "npx tsx workers/discovery.ts",
    "worker:discover:all": "npx tsx worker/src/job-runner/discover-leaderboard.ts binance_futures",
    "daily-check": "bash scripts/daily-check.sh",
    "setup:antigravity": "bash scripts/antigravity-setup.sh",
    "setup:dev": "bash scripts/setup-dev.sh",
    "worker": "npx tsx workers/index.ts",
    "worker:seed": "npx tsx workers/index.ts --seed",
    "worker:discover:platform": "npx tsx workers/discovery.ts --platform",
    "prepare": "husky || true",
    "cap:sync": "npx cap sync",
    "cap:build:ios": "next build && next export && npx cap sync ios",
    "cap:build:android": "next build && next export && npx cap sync android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "version:bump:patch": "node scripts/sync-version.mjs --bump patch",
    "version:bump:minor": "node scripts/sync-version.mjs --bump minor",
    "version:bump:major": "node scripts/sync-version.mjs --bump major",
    "security:audit": "npm audit",
    "security:audit:json": "npm audit --json > docs/audit-report-$(date +%Y%m%d).json",
    "security:fix": "npm audit fix",
    "security:check": "npm run security:audit && npm run type-check && npm run lint",
    "validate:env": "npx tsx -e \"require('./lib/env')\"",
    "predev": "npx tsx -e \"try{require('./lib/env')}catch(e){console.warn(e.message)}\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/camera": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/local-notifications": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/share": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@metamask/sdk": "^0.34.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@sentry/nextjs": "10.35.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.0",
    "@tanstack/react-query": "^5.90.20",
    "@upstash/qstash": "^2.9.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "@walletconnect/ethereum-provider": "^2.23.4",
    "capacitor-native-biometric": "^4.2.2",
    "ethers": "^6.16.0",
    "fast-xml-parser": "^5.3.4",
    "html2canvas": "^1.4.1",
    "isomorphic-dompurify": "^2.35.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "node-fetch": "^3.3.2",
    "otpauth": "^9.4.1",
    "p-limit": "^7.2.0",
    "pdfjs-dist": "^4.9.155",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.6",
    "redis": "^5.10.0",
    "server-only": "^0.0.1",
    "siwe": "^3.0.0",
    "stripe": "^20.2.0",
    "swr": "^2.3.8",
    "viem": "^2.45.1",
    "wagmi": "^3.4.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.3.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/nextjs": "^10.2.1",
    "@storybook/react": "^10.2.1",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.9",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.4.2",
    "puppeteer": "^24.35.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "storybook": "^10.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
