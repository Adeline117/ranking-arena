{
  "name": "ranking-arena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=3584' next dev",
    "build": "touch .env && next build",
    "build:webpack": "TURBOPACK=0 next build",
    "analyze": "ANALYZE=true TURBOPACK=0 next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "scrape:details": "node scripts/fetch_details_fast.mjs",
    "scrape:details:force": "node scripts/fetch_details_fast.mjs --force",
    "worker:jobs": "npx tsx worker/src/job-runner/index.ts",
    "worker:discover": "npx tsx workers/discovery.ts",
    "worker:discover:all": "npx tsx worker/src/job-runner/discover-leaderboard.ts binance_futures",
    "daily-check": "bash scripts/daily-check.sh",
    "setup:antigravity": "bash scripts/antigravity-setup.sh",
    "setup:dev": "bash scripts/setup-dev.sh",
    "worker": "npx tsx workers/index.ts",
    "worker:seed": "npx tsx workers/index.ts --seed",
    "worker:discover:platform": "npx tsx workers/discovery.ts --platform",
    "prepare": "husky || true",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "version:bump:patch": "node scripts/sync-version.mjs --bump patch",
    "version:bump:minor": "node scripts/sync-version.mjs --bump minor",
    "version:bump:major": "node scripts/sync-version.mjs --bump major",
    "security:audit": "npm audit",
    "security:audit:json": "npm audit --json > docs/audit-report-$(date +%Y%m%d).json",
    "security:fix": "npm audit fix",
    "security:check": "npm run security:audit && npm run type-check && npm run lint",
    "validate:env": "npx tsx -e \"require('./lib/env')\"",
    "predev": "npx tsx -e \"try{require('./lib/env')}catch(e){console.warn(e.message)}\"",
    "diagnose": "node scripts/diagnose.mjs",
    "check:seasons": "node scripts/check_seasons.mjs",
    "check:status": "node scripts/check_status.mjs",
    "check:freshness": "node scripts/diagnose.mjs --freshness",
    "check:platforms": "node scripts/diagnose.mjs --platforms",
    "check:tables": "node scripts/check_tables.mjs",
    "check:enrichment": "node scripts/check_enrichment.mjs",
    "check:scripts-boundary": "node scripts/check-production-boundary.mjs",
    "backfill:24h": "npx tsx scripts/backfill-window-24h.ts",
    "backfill:risk:7d30d": "npx tsx scripts/backfill-risk-metrics-7d30d.ts",
    "clean:outliers": "npx tsx scripts/clean-mdd-roi-outliers.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@privy-io/react-auth": "^3.13.1",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@sentry/nextjs": "10.35.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.20",
    "@upstash/qstash": "^2.9.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "candlestick-convert": "^7.0.0",
    "ccxt": "^4.5.42",
    "currency.js": "^2.0.4",
    "epubjs": "^0.3.93",
    "framer-motion": "^12.33.2",
    "isomorphic-dompurify": "^2.35.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "otpauth": "^9.4.1",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.6",
    "redis": "^5.10.0",
    "siwe": "^3.0.0",
    "stripe": "^20.2.0",
    "swr": "^2.3.8",
    "viem": "^2.45.3",
    "wagmi": "^3.4.4",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "overrides": {},
  "devDependencies": {
    "@next/bundle-analyzer": "^15.3.9",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.4.2",
    "puppeteer": "^24.37.5",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
